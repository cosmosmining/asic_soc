{
    "//": "OpenLane (v1) config for the RV32IM pipeline -> sky130 GDSII.",
    "//run": "On a Docker host: cd $OPENLANE; ./flow.tcl -design <this dir>",
    "DESIGN_NAME": "riscv_pipeline",
    "VERILOG_FILES": [
        "dir::../../rtl/cpu_riscv/regfile.sv",
        "dir::../../rtl/cpu_riscv/alu.sv",
        "dir::../../rtl/cpu_riscv/riscv_pipeline.sv"
    ],
    "VERILOG_INCLUDE_DIRS": ["dir::../../rtl/common"],
    "SYNTH_DEFINES": [],

    "CLOCK_PORT": "clk",
    "CLOCK_NET": "clk",
    "CLOCK_PERIOD": 12.0,

    "FP_PDN_VOFFSET": 7,
    "FP_PDN_HOFFSET": 7,
    "FP_CORE_UTIL": 40,
    "PL_TARGET_DENSITY": 0.50,

    "DIE_AREA": "0 0 600 600",
    "FP_SIZING": "absolute",

    "SYNTH_STRATEGY": "AREA 0",
    "PL_RESIZER_DESIGN_OPTIMIZATIONS": true,
    "GLB_RESIZER_DESIGN_OPTIMIZATIONS": true,

    "RUN_CTS": true,
    "RUN_KLAYOUT_DRC": true,
    "MAGIC_DRC_USE_GDS": true,
    "RUN_LVS": true,

    "//pdk": "set by the OpenLane environment",
    "pdk::sky130*": {
        "FP_CORE_UTIL": 40,
        "CLOCK_PERIOD": 12.0
    }
}
